# Firebase 웹 앱 설정값 (Firebase 콘솔 > 프로젝트 설정 > 내 앱 > SDK 설정에서 복사)
# 이 파일을 복사해 .env 로 저장하고 실제 값을 채우세요.  (.env 는 git 에 커밋하지 마세요)
#
# 주의: RTDB 를 쓰므로 databaseURL 이 반드시 필요합니다.
VITE_FIREBASE_API_KEY=여기에_apiKey
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef
